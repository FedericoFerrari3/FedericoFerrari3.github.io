---
import type { Locale } from '../config';
import { useTranslations } from '../i18n/ui';
import { localizePath, switchLocalePath, otherLocale, isActive } from '../i18n/utils';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const pathname = Astro.url.pathname;
const other = otherLocale(locale);
const altPath = switchLocalePath(pathname, other);

// Plain nav links. CV is rendered separately (as a pill grouped with the tools) so that on
// mobile it sits on the actions row and the link row stays even/centered.
const links: { href: string; label: string }[] = [
  { href: '/', label: t('nav.home') },
  { href: '/work', label: t('nav.work') },
  { href: '/about', label: t('nav.about') },
  { href: '/contact', label: t('nav.contact') },
];
---
<header class="site-header">
  <div class="container">
    <a class="brand" href={localizePath('/', locale)}>Federico&nbsp;<span>Ferrari</span></a>
    <nav class="nav" aria-label="Primary">
      {links.map((l) => (
        <a
          href={localizePath(l.href, locale)}
          aria-current={isActive(pathname, l.href, locale) ? 'page' : undefined}
        >{l.label}</a>
      ))}
    </nav>
    <div class="header-tools">
      <a
        class="cv-link"
        href={localizePath('/cv', locale)}
        aria-current={isActive(pathname, '/cv', locale) ? 'page' : undefined}
      >{t('nav.cv')}</a>
      <a class="lang-toggle" href={altPath} data-lang-switch={other} hreflang={other} rel="alternate">{t('lang.switch')}</a>
      <button type="button" class="theme-toggle" data-theme-toggle aria-label={t('theme.toggle')} title={t('theme.toggle')}>
        <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>
    </div>
  </div>
</header>
<script>
  // Persist a manual language choice so the root auto-detector respects it next time.
  document.querySelectorAll<HTMLAnchorElement>('a[data-lang-switch]').forEach((a) => {
    a.addEventListener('click', () => {
      try { localStorage.setItem('lang', a.getAttribute('data-lang-switch') || ''); } catch (_) {}
    });
  });

  // Light/dark toggle. Initial theme is set pre-paint in Base.astro; here we only flip + persist.
  const THEME_COLOR = { light: '#ffffff', dark: '#0a0f0e' } as const;
  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const d = document.documentElement;
      const next = d.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
      d.setAttribute('data-theme', next);
      // Keep the browser-chrome tint (iOS Safari toolbar / overscroll) in sync with the site theme.
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', THEME_COLOR[next]);
      // Safari (iOS + macOS) can leave parts of the page painted in the old palette
      // after the [data-theme] flip. Hiding the body for one synchronous layout pass
      // forces a full repaint; it happens within this frame, so nothing flashes.
      const b = document.body;
      b.style.display = 'none';
      void b.offsetHeight;
      b.style.display = '';
      try { localStorage.setItem('theme', next); } catch (_) {}
    });
  });
</script>
